# DO NOT COMMIT a .env file with real values. This is the dev template only.
# Source: docs/08-deployment.md §1.4 — every var listed there must appear here.
# Per D-24: AUTH_JWT_SECRET ships as a placeholder; real prod secrets come from
# environment variables, never YAML.

# Postgres
POSTGRES_DB=tripplanner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Per-service DB users (D-08; matches infra/postgres/init.sql)
AUTH_DB_USER=auth_svc
AUTH_DB_PASSWORD=auth_svc
TRIP_DB_USER=trip_svc
TRIP_DB_PASSWORD=trip_svc
DESTINATION_DB_USER=destination_svc
DESTINATION_DB_PASSWORD=destination_svc

# Eureka
EUREKA_URL=http://localhost:8761/eureka

# Auth (Phase 1+ consumes; placeholder shipped now per D-24)
AUTH_JWT_SECRET=dev-only-32-byte-secret-replace-in-prod
AUTH_JWT_ACCESS_TTL_SEC=900
AUTH_JWT_REFRESH_TTL_SEC=604800

# SMTP (Mailhog default; Phase 2+ consumes)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@tripplanner.local

# External providers (Phase 4+ consumes)
OPENTRIPMAP_API_KEY=
FOURSQUARE_API_KEY=

# Tracing
ZIPKIN_BASE_URL=http://localhost:9411

# Frontend
VITE_API_URL=http://localhost:8080

# Phase 2 — auth-service (02-CONTEXT.md D-02/D-03/D-12)
MAIL_FROM=no-reply@tripplanner.local
FRONTEND_BASE_URL=http://localhost:5173
AUTH_COOKIE_SECURE=false
