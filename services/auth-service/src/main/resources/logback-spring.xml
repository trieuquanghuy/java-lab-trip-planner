<!--
  Source: 00-PATTERNS.md Bucket C (lines 415-422) — same single-line include pattern used by every
  service that depends on libs/observability (Convention C8).

  The shared logback-spring-base.xml is on the classpath via
  implementation(project(":libs:observability")) in build.gradle.kts. It defines the JSON encoder
  + MDC field set (timestamp, level, service, traceId, spanId, userId, requestId, message,
  stackTrace) per docs/02-architecture.md §6.3.

  auth-service is on the trace path (servlet stack — MdcEnrichmentFilter activates via
  ObservabilityAutoConfiguration's @ConditionalOnClass(jakarta.servlet.Filter)).
-->
<configuration>
    <include resource="logback-spring-base.xml" />
</configuration>
